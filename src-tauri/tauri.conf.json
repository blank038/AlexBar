{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlexBar",
  "version": "0.1.1",
  "identifier": "com.alexbar.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "AlexBar",
        "width": 320,
        "height": 360,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "create": false,
        "title": "Settings",
        "width": 600,
        "height": 540,
        "center": true,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
